# SUPABASE: Required for database and authentication.
# Get your keys from your Supabase project settings.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# VAPID keys for Web Push notifications.
# Generate with: npx web-push generate-vapid-keys
# Set VAPID_PRIVATE_KEY as a Supabase secret: supabase secrets set VAPID_PRIVATE_KEY=xxx VAPID_PUBLIC_KEY=xxx
VITE_VAPID_PUBLIC_KEY=""

# GROQ_API_KEY: Set this as a SECRET in Supabase Edge Functions (NOT in frontend env).
# Run: supabase secrets set GROQ_API_KEY=your_groq_api_key_here
# Get your API key from https://console.groq.com/keys
